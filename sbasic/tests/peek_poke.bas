' Test PEEK/POKE, SCREEN, DEF SEG, STRIG, STICK
SCREEN 0
POKE 1000, 42
POKE 1001, 255
POKE 1002, 0
PRINT "PEEK(1000) ="; PEEK(1000)
PRINT "PEEK(1001) ="; PEEK(1001)
PRINT "PEEK(1002) ="; PEEK(1002)
PRINT "PEEK(1003) ="; PEEK(1003)
' Round-trip multi-byte value
DIM v AS INTEGER
v = 12345
POKE 2000, v MOD 256
POKE 2001, v \ 256
PRINT "Stored"; v; "got"; PEEK(2000) + PEEK(2001) * 256
SCREEN 13
' DEF SEG test
DEF SEG = 100
POKE 0, 77
POKE 1, 88
DEF SEG
PRINT "PEEK(1600) ="; PEEK(1600)
PRINT "PEEK(1601) ="; PEEK(1601)
DEF SEG = 100
PRINT "Via seg PEEK(0) ="; PEEK(0)
DEF SEG
' STRIG/STICK stubs
PRINT "STRIG(0) ="; STRIG(0)
PRINT "STICK(0) ="; STICK(0)
PRINT "Done"
